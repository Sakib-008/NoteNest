generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id         Int      @id @default(autoincrement())
  fullName   String
  email      String   @unique
  password   String
  department String
  semester   String
  createdAt  DateTime @default(now())
}

model Note{
  id Int @id @default(autoincrement())
  title String
  courseCode String
  department String
  semester String
  filePath String
  uploadedAt DateTime @default(now())
}